# ── Server ──────────────────────────────────────────────
PORT=8080
NODE_ENV=development
# Comma-separated list of allowed browser origins (the SPA)
CLIENT_ORIGIN=http://localhost:5173

# ── Supabase ────────────────────────────────────────────
# Project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=
# Service-role key (server only — full access, NEVER ship to the browser)
SUPABASE_SERVICE_ROLE_KEY=
# Anon/public key (used by the browser for signed-URL uploads)
SUPABASE_ANON_KEY=
# Private storage bucket name for all project files
SUPABASE_STORAGE_BUCKET=century-joy-files

# ── Auth / JWT ──────────────────────────────────────────
# Long random strings. Generate with: openssl rand -hex 48
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# ── Email (Resend) ──────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM="Century Joy <noreply@centuryjoy.in>"
# Where the SPA lives, used to build links inside emails
APP_BASE_URL=http://localhost:5173
# Address that receives "studio flagged an issue" + dead-letter alerts
ADMIN_ALERT_EMAIL=
